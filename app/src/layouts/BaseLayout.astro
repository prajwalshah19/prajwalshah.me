---
interface Props {
  title?: string;
}
const { title = 'Prajwal Shah' } = Astro.props;
---

<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&family=Roboto:wght@300;400;500;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <script is:inline>
      // Restore theme from localStorage before paint
      (function() {
        const theme = localStorage.getItem('theme');
        if (theme) {
          document.documentElement.className = theme;
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  @import '../index.css';
  @import '../styles/markdown-overrides.css';
</style>
